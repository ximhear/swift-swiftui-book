# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is gitignored — do NOT commit real credentials.

# Gmail address used as the SMTP sender
GMAIL_USER=gzonelee@gmail.com

# 16-character app password from https://myaccount.google.com/apppasswords
# (NOT your regular Gmail password — Google blocks those over SMTP)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
